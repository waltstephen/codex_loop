{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["done", "continue", "blocked"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "round_summary_markdown": {
      "type": "string",
      "minLength": 1
    },
    "completion_summary_markdown": {
      "type": "string"
    }
  },
  "required": [
    "status",
    "confidence",
    "reason",
    "next_action",
    "round_summary_markdown",
    "completion_summary_markdown"
  ]
}
